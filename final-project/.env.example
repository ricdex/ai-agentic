# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GitHub — token with: repo, issues, pull_requests scopes
GITHUB_TOKEN=ghp_...

# GitHub Webhook secret (set when configuring the webhook)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Redis (leave empty for local docker-compose, fill for cloud VMs)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
